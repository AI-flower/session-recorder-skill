#!/usr/bin/env python3
"""post-tool-use: Auto-record tool calls to session log via stdin JSON."""

import sys
import json
import os

# Add hooks directory to path for shared utils
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from session_recorder_utils import get_or_create_log_dir, now_ts, append_log, read_stdin


def extract_summary(tool_name, tool_input, tool_response):
    """Extract structured target + result_summary per tool type."""
    inp = tool_input if isinstance(tool_input, dict) else {}
    resp = tool_response if isinstance(tool_response, str) else str(tool_response or "")

    target = ""
    result_summary = ""

    if tool_name == "Bash":
        cmd = inp.get("command", "")
        target = cmd[:80]
        # Try to extract exit code from response
        if "exit code" in resp.lower():
            result_summary = resp[:100]
        else:
            result_summary = resp[:100]

    elif tool_name == "Write":
        target = inp.get("file_path", "")
        content = inp.get("content", "")
        line_count = content.count("\n") + (1 if content else 0)
        result_summary = f"{line_count} lines"

    elif tool_name == "Edit":
        target = inp.get("file_path", "")
        old = inp.get("old_string", "")[:30]
        new = inp.get("new_string", "")[:30]
        result_summary = f"'{old}' -> '{new}'"

    elif tool_name == "Read":
        target = inp.get("file_path", "")
        result_summary = f"{len(resp)} chars"

    elif tool_name == "Glob":
        target = inp.get("pattern", "")
        # Count matches (lines in response)
        matches = len(resp.strip().split("\n")) if resp.strip() else 0
        result_summary = f"{matches} matches"

    elif tool_name == "Grep":
        pattern = inp.get("pattern", "")
        path = inp.get("path", "")
        target = f"{pattern} in {path}" if path else pattern
        matches = len(resp.strip().split("\n")) if resp.strip() else 0
        result_summary = f"{matches} matches"

    elif tool_name == "Skill":
        target = inp.get("skill", "")
        result_summary = "loaded" if resp and "error" not in resp.lower()[:200] else "failed"

    elif tool_name == "Agent":
        target = inp.get("description", "")[:80]
        result_summary = "dispatched"

    elif tool_name == "WebSearch":
        target = inp.get("query", "")[:80]
        matches = resp.count("http") if resp else 0
        result_summary = f"~{matches} results"

    elif tool_name == "WebFetch":
        target = inp.get("url", "")[:80]
        result_summary = f"{len(resp)} chars"

    elif tool_name == "TaskCreate":
        target = inp.get("subject", "")[:80]
        result_summary = "created"

    elif tool_name == "TaskUpdate":
        target = f"task #{inp.get('taskId', '?')}"
        status = inp.get("status", "")
        result_summary = status if status else "updated"

    else:
        # Generic fallback
        target = str(tool_input)[:80] if tool_input else ""
        result_summary = resp[:100] if resp else ""

    return target, result_summary


def main():
    try:
        data = read_stdin()
        if not data:
            sys.exit(0)

        tool_name = data.get("tool_name", "unknown")
        tool_input = data.get("tool_input", {})
        tool_response = data.get("tool_response", "")
        cwd = data.get("cwd", os.getcwd())

        # Skip recording our own log writes (prevent recursion)
        if tool_name == "Bash":
            cmd = ""
            if isinstance(tool_input, dict):
                cmd = tool_input.get("command", "")
            # Only skip if the command writes to our log file (prevent recursion)
            if ".session-recorder/session-log.jsonl" in cmd:
                sys.exit(0)
            # Also skip if command writes to session-summary.md
            if ".session-recorder/session-summary.md" in cmd:
                sys.exit(0)

        # Find or create log directory
        log_dir = get_or_create_log_dir(cwd)
        if not log_dir:
            sys.exit(0)

        # Extract summary
        target, result_summary = extract_summary(tool_name, tool_input, tool_response)

        # Build and append log entry
        entry = {
            "source": "hook",
            "type": "tool_call",
            "tool": tool_name,
            "target": target,
            "result_summary": result_summary,
            "ts": now_ts(),
        }

        append_log(log_dir, entry)

    except Exception as e:
        try:
            sys.stderr.write(f"[session-recorder:post-tool-use] {e}\n")
        except Exception:
            pass

    sys.exit(0)


if __name__ == "__main__":
    main()
