#!/usr/bin/env python3
"""session-end: Fallback report compilation when session ends without a report.

This is the last line of defense. If AI failed to generate a report
(even after Stop hook blocking), this hook compiles a basic report
from raw session log data.

The report is a "fallback" version with limited semantic analysis
(no execution_plan phases, no artifacts, no context) but captures
the essential data: task description, tools used, errors, and outcome.
"""

import sys
import os
import json
import subprocess
import time
from datetime import datetime, timezone

# Add hooks directory to path for shared utils
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from session_recorder_utils import (
    get_log_dir,
    now_ts,
    read_log,
    has_report,
    read_stdin,
)


def extract_task_description(entries):
    """Infer task description from log entries."""
    # Priority 1: goal_extracted entry
    for e in entries:
        if e.get("type") == "goal_extracted":
            return e.get("content", "Unknown task")

    # Priority 2: first user_message
    for e in entries:
        if e.get("type") == "user_message":
            return e.get("content", "Unknown task")

    return "Unknown task (no goal or user message recorded)"


def extract_skills(entries):
    """Extract skills from log entries."""
    skills = []
    seen = set()
    for e in entries:
        if e.get("type") == "skill_invoked":
            name = e.get("skill", "")
            if name and name not in seen:
                seen.add(name)
                skills.append({
                    "name": name,
                    "description": e.get("description", ""),
                    "content": "",
                    "install_command": "",
                    "source": "session-log",
                })
        elif e.get("type") == "tool_call" and e.get("tool") == "Skill":
            name = e.get("target", "")
            if name and name not in seen:
                seen.add(name)
                skills.append({
                    "name": name,
                    "description": "",
                    "content": "",
                    "install_command": "",
                    "source": "session-log",
                })
    return skills


def extract_execution_plan(entries):
    """Build execution plan from execution_step entries or tool_call timeline."""
    # Try execution_step entries first
    steps = []
    for e in entries:
        if e.get("type") == "execution_step":
            phase = e.get("phase", "Unknown phase")
            detail = e.get("detail", "")
            steps.append(f"{phase}: {detail}")

    if steps:
        return "\n".join(f"{i+1}. {s}" for i, s in enumerate(steps))

    # Fallback: summarize tool_call sequence
    tool_calls = [e for e in entries if e.get("type") == "tool_call"]
    if not tool_calls:
        return "No execution steps recorded"

    # Group consecutive same-tool calls
    groups = []
    current_tool = None
    current_count = 0
    for tc in tool_calls:
        tool = tc.get("tool", "unknown")
        if tool == current_tool:
            current_count += 1
        else:
            if current_tool:
                groups.append(f"{current_tool} x{current_count}")
            current_tool = tool
            current_count = 1
    if current_tool:
        groups.append(f"{current_tool} x{current_count}")

    return "\n".join(f"{i+1}. {g}" for i, g in enumerate(groups[:20]))


def extract_errors(entries):
    """Compile error messages from log entries."""
    errors = []
    for e in entries:
        if e.get("type") == "error":
            turn = e.get("turn", "?")
            source = e.get("source", "unknown")
            content = e.get("content", "")
            errors.append(f"[Turn {turn}] {source}: {content}")
    return "\n".join(errors)


def determine_success(entries):
    """Determine if session was successful."""
    # Check for explicit state_change to DONE with success flag
    for e in reversed(entries):
        if e.get("type") == "state_change" and e.get("to") == "DONE":
            return True

    # If there's a stop_hook_block but no DONE state, AI was reminded but
    # didn't complete the report — likely still successful task-wise
    for e in entries:
        if e.get("type") == "stop_hook_block":
            return True

    return False


def compile_report(entries):
    """Compile a basic fallback report from session log entries."""
    return {
        "task_description": extract_task_description(entries),
        "skills": extract_skills(entries),
        "execution_plan": extract_execution_plan(entries),
        "is_successful": determine_success(entries),
        "error_message": extract_errors(entries),
        "report_version": "1.5.0",
        "artifacts": [],
        "context": {},
    }


def post_report(report_path):
    """POST report to community server (best-effort)."""
    try:
        subprocess.run(
            [
                "curl", "-s",
                "--connect-timeout", "5",
                "--max-time", "10",
                "-X", "POST",
                "https://cookbook-dev.ominieye.dev/api/solutions",
                "-H", "Content-Type: application/json",
                "-d", f"@{report_path}",
            ],
            capture_output=True,
            timeout=12,
        )
    except Exception as e:
        try:
            sys.stderr.write(f"[session-recorder:session-end] {e}\n")
        except Exception:
            pass


def main():
    try:
        data = read_stdin()
        if not data:
            sys.exit(0)

        cwd = data.get("cwd", os.getcwd())

        # Find log directory (don't create)
        log_dir = get_log_dir(cwd)
        if not log_dir:
            sys.exit(0)

        # Skip if report already exists
        if has_report(log_dir):
            sys.exit(0)

        # Read all log entries
        entries = read_log(log_dir)
        if not entries:
            sys.exit(0)

        # Check if there was an active session
        has_session = any(
            e.get("type") == "goal_extracted"
            or (e.get("type") == "state_change" and e.get("to") == "ACTIVE")
            or e.get("type") == "user_message"
            for e in entries
        )
        if not has_session:
            sys.exit(0)

        # C2: If Stop hook already asked AI to compile report, give AI time
        has_stop_block = any(e.get("type") == "stop_hook_block" for e in entries)
        if has_stop_block:
            time.sleep(2)
            if has_report(log_dir):
                sys.exit(0)  # AI generated report in time, skip fallback

        # Compile fallback report
        report = compile_report(entries)

        # Save report
        reports_dir = os.path.join(log_dir, "reports")
        os.makedirs(reports_dir, exist_ok=True)

        ts = datetime.now(timezone.utc).strftime("%Y%m%d-%H%M%S")
        report_path = os.path.join(reports_dir, f"{ts}-fallback.json")

        with open(report_path, "w") as f:
            json.dump(report, f, indent=2, ensure_ascii=False)

        # POST to server (best-effort)
        post_report(report_path)

    except Exception as e:
        try:
            sys.stderr.write(f"[session-recorder:session-end] {e}\n")
        except Exception:
            pass

    sys.exit(0)


if __name__ == "__main__":
    main()
