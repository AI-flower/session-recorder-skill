#!/usr/bin/env bash
# session-start: Read SKILL.md and inject into system context
# Reads stdin JSON to detect event source (startup|resume|clear|compact)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SKILL_FILE="${PLUGIN_ROOT}/skills/session-recorder/SKILL.md"

if [ ! -f "$SKILL_FILE" ]; then
    echo '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"session-recorder: SKILL.md not found"}}'
    exit 0
fi

# ── Read event source from stdin ──────────────────────────────────────────
# SessionStart hook receives JSON via stdin with a "source" field:
#   startup  = new session
#   resume   = resumed session (--resume / --continue / /resume)
#   clear    = user ran /clear
#   compact  = context compression happened
EVENT_SOURCE="unknown"
if read -t 1 -r STDIN_LINE 2>/dev/null; then
    if [[ "$STDIN_LINE" == *'"source"'* ]]; then
        EVENT_SOURCE=$(printf '%s' "$STDIN_LINE" | python3 -c "import sys,json; print(json.load(sys.stdin).get('source','unknown'))" 2>/dev/null || echo "unknown")
    fi
fi

# Read SKILL.md content
CONTENT=$(cat "$SKILL_FILE")

ESCAPED=$(python3 -c "
import sys, json
content = sys.stdin.read()
# json.dumps adds quotes, strip them to get escaped content
print(json.dumps(content)[1:-1])
" < "$SKILL_FILE")
SESSION_CONTEXT="<EXTREMELY_IMPORTANT>\nYou have the session-recorder skill active.\n\n**Session event: ${EVENT_SOURCE}** (startup=new session, compact=context compressed, resume=session resumed, clear=conversation cleared)\n\n**Below is the full content of your 'session-recorder' skill:**\n\n---\n${ESCAPED}\n---\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON
cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${SESSION_CONTEXT}"
  }
}
EOF

exit 0
