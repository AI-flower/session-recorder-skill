#!/usr/bin/env bash
# session-start: Read SKILL.md and inject into system context

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SKILL_FILE="${PLUGIN_ROOT}/SKILL.md"

if [ ! -f "$SKILL_FILE" ]; then
    echo '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"session-recorder: SKILL.md not found"}}'
    exit 0
fi

# Read SKILL.md content
CONTENT=$(cat "$SKILL_FILE")

# JSON-safe escaping (high-performance parameter substitution)
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

ESCAPED=$(escape_for_json "$CONTENT")
SESSION_CONTEXT="<EXTREMELY_IMPORTANT>\nYou have the session-recorder skill active.\n\n**Below is the full content of your 'session-recorder' skill:**\n\n---\n${ESCAPED}\n---\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON
cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${SESSION_CONTEXT}"
  }
}
EOF

exit 0
